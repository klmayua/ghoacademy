---
const navLinks = [
  { label: "About",      href: "#about"      },
  { label: "Curriculum", href: "#curriculum" },
  { label: "Instructor", href: "#instructor" },
  { label: "Pricing",    href: "#pricing"    },
  { label: "FAQ",        href: "#faq"        },
];
---
<nav
  id="main-nav"
  style="position:sticky;top:36px;z-index:50;background:#071A35;border-bottom:1px solid rgba(214,164,58,0.2);transition:background 0.3s,backdrop-filter 0.3s,box-shadow 0.3s;"
>
  <div style="max-width:1440px;margin:0 auto;padding:0 2.5rem;height:80px;display:flex;align-items:center;justify-content:space-between;">
    <!-- Logo -->
    <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:10px;flex-shrink:0;">
      <div style="display:flex;flex-direction:column;gap:7px;">
        <span style="font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;color:#fff;letter-spacing:0.5px;line-height:1;">GHO Academy</span>
        <span style="font-size:9px;color:#D6A43A;letter-spacing:4px;font-weight:700;text-transform:uppercase;line-height:1;">Global Health Otherwise</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <div class="desktop-nav" style="display:flex;align-items:center;gap:2.25rem;">
      {navLinks.map(link => (
        <a href={link.href} style="font-size:14px;color:rgba(255,255,255,0.65);text-decoration:none;font-weight:500;letter-spacing:0.5px;transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.65)'">{link.label}</a>
      ))}
    </div>

    <!-- CTA -->
    <div style="display:flex;align-items:center;gap:14px;">
      <a href="/login" class="login-link" style="font-size:14px;color:rgba(255,255,255,0.7);text-decoration:none;font-weight:500;letter-spacing:0.3px;transition:color 0.2s;display:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.7)'">Sign In</a>
      <a
        href="#register"
        style="background:#D6A43A;color:#071A35;font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:11px 24px;border-radius:4px;text-decoration:none;white-space:nowrap;cursor:pointer;transition:background 0.2s,transform 0.15s;"
        onmouseover="this.style.background='#c49030';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='#D6A43A';this.style.transform=''"
      >Apply Now — Sep 2026</a>
      <!-- Mobile hamburger -->
      <button id="mobile-nav-btn" style="display:none;background:none;border:none;color:#fff;font-size:24px;cursor:pointer;padding:4px;">
        <i class="ti ti-menu-2"></i>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-drawer" style="display:none;background:#071A35;border-top:1px solid rgba(214,164,58,0.15);padding:1rem 1.5rem 1.5rem;">
    {navLinks.map(link => (
      <a href={link.href} style="display:block;padding:10px 0;color:rgba(255,255,255,0.75);text-decoration:none;font-size:15px;font-weight:500;border-bottom:1px solid rgba(255,255,255,0.05);">{link.label}</a>
    ))}
    <a href="/login" style="display:block;padding:10px 0;color:rgba(255,255,255,0.75);text-decoration:none;font-size:15px;font-weight:500;border-bottom:1px solid rgba(255,255,255,0.05);">Sign In</a>
    <a href="#register" style="display:block;margin-top:1rem;background:#D6A43A;color:#071A35;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:12px;text-align:center;border-radius:4px;text-decoration:none;">Apply Now — September 2026</a>
  </div>
</nav>

<style>
  #main-nav { background: #071A35 !important; }
  @media (max-width: 768px) {
    .desktop-nav { display: none !important; }
    .login-link  { display: none !important; }
    #mobile-nav-btn { display: block !important; }
  }
  @media (min-width: 769px) {
    .login-link { display: block !important; }
  }
</style>

<script>
  const btn    = document.getElementById('mobile-nav-btn');
  const drawer = document.getElementById('mobile-drawer');
  btn?.addEventListener('click', () => {
    drawer!.style.display = drawer!.style.display === 'none' ? 'block' : 'none';
  });
  drawer?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => { drawer.style.display = 'none'; });
  });
</script>
