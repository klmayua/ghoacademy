---
const navLinks = [
  { label: "About",      href: "/#about"      },
  { label: "Curriculum", href: "/#curriculum" },
  { label: "Instructor", href: "/#instructor" },
  { label: "Pricing",    href: "/#pricing"    },
  { label: "FAQ",        href: "/#faq"        },
];
---
<!-- ═══ TOP NAV ═══ Desktop: full | Mobile: Logo left + CTA right only ═══ -->
<nav id="main-nav" style="position:relative;z-index:50;background:#071A35;border-bottom:1px solid rgba(214,164,58,0.2);transition:background 0.3s,box-shadow 0.3s;">
  <div style="max-width:1440px;margin:0 auto;padding:0 2.5rem;height:80px;display:flex;align-items:center;justify-content:space-between;">

    <!-- Logo -->
    <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:10px;flex-shrink:0;">
      <div style="display:flex;flex-direction:column;gap:4px;">
        <span style="font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;color:#F5F0E8;letter-spacing:0.5px;line-height:1;">GHO Academy</span>
        <span class="logo-sub" style="font-size:9px;color:#D6A43A;letter-spacing:4px;font-weight:700;text-transform:uppercase;line-height:1;">Global Health Otherwise</span>
      </div>
    </a>

    <!-- Desktop nav links -->
    <div class="desktop-nav" style="display:flex;align-items:center;gap:2.25rem;">
      {navLinks.map(link => (
        <a href={link.href} style="font-size:14px;color:rgba(255,255,255,0.65);text-decoration:none;font-weight:500;letter-spacing:0.5px;transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.65)'">{link.label}</a>
      ))}
    </div>

    <!-- Desktop CTAs -->
    <div class="desktop-cta" style="display:flex;align-items:center;gap:14px;">
      <a href="/login" style="font-size:14px;color:rgba(255,255,255,0.7);text-decoration:none;font-weight:500;letter-spacing:0.3px;transition:color 0.2s;display:inline-flex;align-items:center;gap:5px;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.7)'">
        <i class="ti ti-login" style="font-size:15px;"></i>Sign In
      </a>
      <a href="/apply" style="background:#D6A43A;color:#071A35;font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:11px 24px;border-radius:4px;text-decoration:none;white-space:nowrap;cursor:pointer;transition:background 0.2s,transform 0.15s;display:inline-flex;align-items:center;gap:6px;" onmouseover="this.style.background='#c49030';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='#D6A43A';this.style.transform=''">
        <i class="ti ti-arrow-right" style="font-size:15px;"></i>Apply Now — Sep 2026
      </a>
    </div>

    <!-- Mobile top-bar: CTA only (no hamburger) -->
    <div class="mobile-top-cta" style="display:none;align-items:center;">
      <a href="/apply" style="background:#D6A43A;color:#071A35;font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:10px 16px;border-radius:4px;text-decoration:none;display:inline-flex;align-items:center;gap:5px;">
        <i class="ti ti-arrow-right" style="font-size:14px;"></i>Apply Now
      </a>
    </div>

  </div>
</nav>

<!-- ═══ MOBILE BOTTOM NAV BAR (≤768px) ═══ 5 tabs: Home · About · Apply · Curriculum · More ═══ -->
<nav id="mobile-bottom-nav" aria-label="Mobile bottom navigation">
  <a href="/#hero"       class="mob-tab" id="tab-home"       aria-label="Home">       <i class="ti ti-home"></i><span>Home</span></a>
  <a href="/#about"      class="mob-tab" id="tab-about"      aria-label="About">      <i class="ti ti-info-circle"></i><span>About</span></a>
  <a href="/apply"      class="mob-tab mob-tab-apply"        aria-label="Apply Now">
    <span class="mob-apply-pill"><i class="ti ti-rocket"></i><span>Apply</span></span>
  </a>
  <a href="/#curriculum" class="mob-tab" id="tab-curriculum" aria-label="Curriculum"> <i class="ti ti-books"></i><span>Curriculum</span></a>
  <button class="mob-tab mob-tab-more" id="mob-more-btn" aria-label="More" aria-expanded="false">
    <i class="ti ti-dots"></i><span>More</span>
  </button>
</nav>

<!-- ═══ MOBILE MORE: dark overlay ═══ -->
<div id="mob-more-overlay"></div>

<!-- ═══ MOBILE MORE: slide-up panel ═══ -->
<div id="mob-more-panel" role="dialog" aria-label="More options">
  <div class="mob-more-handle"></div>

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
    <span style="font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:800;color:#F5F0E8;text-transform:uppercase;letter-spacing:1px;">More</span>
    <button class="mob-more-close" style="background:rgba(255,255,255,0.07);border:none;border-radius:50%;width:32px;height:32px;color:rgba(255,255,255,0.6);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;"><i class="ti ti-x"></i></button>
  </div>

  <!-- Nav links -->
  <div class="mob-more-list">
    <a href="/#instructor" class="mob-more-row mob-more-close">
      <span class="mob-more-icon"><i class="ti ti-user-star"></i></span><span>Instructor</span><i class="ti ti-chevron-right mob-chev"></i>
    </a>
    <a href="/#faq" class="mob-more-row mob-more-close">
      <span class="mob-more-icon"><i class="ti ti-help-circle"></i></span><span>FAQ</span><i class="ti ti-chevron-right mob-chev"></i>
    </a>
    <a href="/#pricing" class="mob-more-row mob-more-close">
      <span class="mob-more-icon"><i class="ti ti-tag"></i></span><span>Pricing</span><i class="ti ti-chevron-right mob-chev"></i>
    </a>
    <a href="/login" class="mob-more-row">
      <span class="mob-more-icon"><i class="ti ti-login"></i></span><span>Sign In</span><i class="ti ti-chevron-right mob-chev"></i>
    </a>
  </div>

  <div style="height:1px;background:rgba(214,164,58,0.15);margin:1rem 0;"></div>
  <p style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(245,240,232,0.35);font-weight:700;margin-bottom:0.75rem;">Get in Touch</p>

  <!-- Chat links -->
  <div class="mob-more-list">
    <a href="https://whatsapp.com/channel/0029Vb15K9p7tkjHbKE2L43D" target="_blank" rel="noopener" class="mob-more-row mob-row-green">
      <span class="mob-more-icon mob-icon-green"><i class="ti ti-brand-whatsapp"></i></span><span>Chat on WhatsApp</span><i class="ti ti-arrow-up-right mob-chev"></i>
    </a>
    <a href="mailto:lebaiins@gmail.com?subject=GHO Academy Enquiry" class="mob-more-row mob-row-gold">
      <span class="mob-more-icon mob-icon-gold"><i class="ti ti-mail"></i></span><span>Send an Email</span><i class="ti ti-arrow-up-right mob-chev"></i>
    </a>
  </div>

  <!-- CTA inside panel -->
  <a href="/apply" class="mob-more-close" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:1.25rem;background:#D6A43A;color:#041326;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:14px;border-radius:8px;text-decoration:none;">
    <i class="ti ti-arrow-right" style="font-size:16px;"></i>Apply Now — Sep 2026
  </a>
</div>

<style>
  /* ── Desktop defaults ─────────────────────────────────── */
  #main-nav        { background: #071A35 !important; }
  .desktop-nav     { display: flex; }
  .desktop-cta     { display: flex; }
  .mobile-top-cta  { display: none !important; }
  #mobile-bottom-nav { display: none !important; }

  /* Hide mobile-only elements above 768px */
  @media (min-width: 769px) {
    #mob-more-panel   { display: none !important; }
    #mob-more-overlay { display: none !important; }
  }

  /* ── Mobile (≤768px) ──────────────────────────────────── */
  @media (max-width: 768px) {
    /* Strip top nav to logo + CTA only */
    .desktop-nav    { display: none !important; }
    .desktop-cta    { display: none !important; }
    .logo-sub       { display: none !important; }
    .mobile-top-cta { display: flex !important; }
    #main-nav > div { padding: 0 1.25rem !important; height: 60px !important; }

    /* Bottom nav bar */
    #mobile-bottom-nav {
      display: flex !important;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 100;
      background: #071A35;
      border-top: 1px solid rgba(214,164,58,0.22);
      padding-bottom: env(safe-area-inset-bottom, 0px);
      height: calc(60px + env(safe-area-inset-bottom, 0px));
      align-items: stretch;
    }

    /* Individual tab */
    .mob-tab {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 3px;
      text-decoration: none;
      color: rgba(245,240,232,0.4);
      font-size: 9.5px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      border: none;
      background: none;
      cursor: pointer;
      min-height: 48px;
      padding: 6px 4px;
      transition: color 0.18s;
      -webkit-tap-highlight-color: transparent;
      font-family: 'Barlow Condensed', sans-serif;
    }
    .mob-tab i       { font-size: 21px; display: block; }
    .mob-tab:active  { color: #D6A43A; }
    .mob-tab.active  { color: #D6A43A; }

    /* Apply hero tab */
    .mob-tab-apply   { color: transparent !important; flex: 1.2; }
    .mob-apply-pill {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      background: #D6A43A;
      border-radius: 14px;
      padding: 7px 10px;
      color: #041326;
      font-size: 9.5px;
      font-weight: 800;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      min-width: 52px;
      box-shadow: 0 -2px 12px rgba(214,164,58,0.4);
      margin-top: -6px;
      font-family: 'Barlow Condensed', sans-serif;
    }
    .mob-apply-pill i { font-size: 19px; }

    /* More button active state */
    .mob-tab-more.open { color: #D6A43A; }

    /* Overlay — hidden initially via opacity/pointer-events, not display:none */
    #mob-more-overlay {
      position: fixed;
      inset: 0;
      background: rgba(4,19,38,0.72);
      z-index: 98;
      backdrop-filter: blur(3px);
      -webkit-backdrop-filter: blur(3px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }
    #mob-more-overlay.open {
      opacity: 1;
      pointer-events: auto;
    }

    /* Slide-up More panel */
    #mob-more-panel {
      display: block;
      position: fixed;
      bottom: calc(60px + env(safe-area-inset-bottom, 0px));
      left: 0; right: 0;
      z-index: 99;
      background: #071A35;
      border-top: 1px solid rgba(214,164,58,0.25);
      border-radius: 20px 20px 0 0;
      padding: 0.75rem 1.25rem 1.5rem;
      transform: translateY(100%);
      transition: transform 0.3s cubic-bezier(0.32,0.72,0,1);
      max-height: 78vh;
      overflow-y: auto;
    }
    #mob-more-panel.open { transform: translateY(0); }

    .mob-more-handle {
      width: 36px; height: 4px;
      background: rgba(245,240,232,0.18);
      border-radius: 2px;
      margin: 0 auto 1.25rem;
    }

    /* More rows */
    .mob-more-list  { display: flex; flex-direction: column; gap: 6px; }
    .mob-more-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 11px 14px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 10px;
      text-decoration: none;
      color: rgba(245,240,232,0.85);
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      min-height: 48px;
      -webkit-tap-highlight-color: transparent;
    }
    .mob-more-row:active { background: rgba(255,255,255,0.09); }
    .mob-more-icon {
      width: 36px; height: 36px;
      border-radius: 8px;
      background: rgba(214,164,58,0.1);
      border: 1px solid rgba(214,164,58,0.18);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      color: #D6A43A;
      font-size: 18px;
    }
    .mob-chev { margin-left: auto; font-size: 14px; color: rgba(245,240,232,0.22); }

    /* Green / Gold row variants */
    .mob-row-green               { color: #25D366; }
    .mob-icon-green { background: rgba(37,211,102,0.1);  border-color: rgba(37,211,102,0.2);  color: #25D366; }
    .mob-row-gold                { color: #D6A43A; }
    .mob-icon-gold  { background: rgba(214,164,58,0.12); border-color: rgba(214,164,58,0.25); color: #D6A43A; }

    /* Push page body above fixed bottom nav */
    body { padding-bottom: calc(60px + env(safe-area-inset-bottom, 0px)) !important; }
  }
</style>

<script>
  // Expose functions on window so inline onclick and event listeners work
  // regardless of Astro's module script scoping
  (function () {
    function closeMobileMore() {
      const panel   = document.getElementById('mob-more-panel');
      const overlay = document.getElementById('mob-more-overlay');
      const btn     = document.getElementById('mob-more-btn');
      panel?.classList.remove('open');
      overlay?.classList.remove('open');
      btn?.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
    }

    function toggleMobileMore() {
      const panel = document.getElementById('mob-more-panel');
      if (panel?.classList.contains('open')) {
        closeMobileMore();
      } else {
        panel?.classList.add('open');
        document.getElementById('mob-more-overlay')?.classList.add('open');
        document.getElementById('mob-more-btn')?.classList.add('open');
        document.getElementById('mob-more-btn')?.setAttribute('aria-expanded', 'true');
      }
    }

    // Wire up More button via addEventListener (not onclick attr)
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('mob-more-btn')?.addEventListener('click', toggleMobileMore);
      document.getElementById('mob-more-overlay')?.addEventListener('click', closeMobileMore);

      // All items with mob-more-close class dismiss the panel
      document.querySelectorAll('.mob-more-close').forEach(el => {
        el.addEventListener('click', closeMobileMore);
      });

      // Active tab highlight on scroll
      const sectionIds = ['hero', 'about', 'curriculum', 'instructor', 'pricing', 'faq'];
      const tabMap: Record<string, HTMLElement | null> = {
        hero:       document.getElementById('tab-home'),
        about:      document.getElementById('tab-about'),
        curriculum: document.getElementById('tab-curriculum'),
      };
      window.addEventListener('scroll', () => {
        let current = 'hero';
        sectionIds.forEach(id => {
          const el = document.getElementById(id);
          if (el && window.scrollY >= el.offsetTop - 130) current = id;
        });
        Object.entries(tabMap).forEach(([id, tab]) => {
          tab?.classList.toggle('active', id === current);
        });
      }, { passive: true });
    });
  })();
</script>
