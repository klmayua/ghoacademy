---
import { SITE } from '../../data/site';
const { course, instructor } = SITE;
---
<section
  id="hero"
  style="background:#0B1C3D;padding:5rem 1.5rem 4rem;padding-top:calc(5rem + 60px);position:relative;overflow:hidden;"
>
  <!-- Grid texture -->
  <div style="position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 79px,rgba(201,146,42,0.04) 79px,rgba(201,146,42,0.04) 80px),repeating-linear-gradient(90deg,transparent,transparent 79px,rgba(201,146,42,0.03) 79px,rgba(201,146,42,0.03) 80px);pointer-events:none;"></div>
  <!-- Radial glow -->
  <div style="position:absolute;top:-40%;left:-10%;width:60%;height:200%;background:radial-gradient(ellipse,rgba(0,168,150,0.07) 0%,transparent 70%);pointer-events:none;"></div>

  <div style="max-width:1200px;margin:0 auto;text-align:center;position:relative;z-index:1;">
    <!-- Eyebrow -->
    <p style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#00A896;font-weight:600;margin-bottom:1.2rem;">
      Global Health Otherwise · Executive Education · {course.cohort}
    </p>

    <!-- Main headline -->
    <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(44px,8vw,80px);font-weight:800;color:#fff;line-height:0.95;text-transform:uppercase;letter-spacing:-1px;margin-bottom:0.5rem;">
      Global Public Health
    </h1>
    <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(44px,8vw,80px);font-weight:800;color:#C9922A;line-height:0.95;text-transform:uppercase;letter-spacing:-1px;margin-bottom:0.5rem;">
      Innovation, Entrepreneurship
    </h1>
    <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(44px,8vw,80px);font-weight:800;color:#fff;line-height:0.95;text-transform:uppercase;letter-spacing:-1px;margin-bottom:1.25rem;">
      &amp; Leadership
    </h1>

    <!-- Subline -->
    <p style="font-size:12px;color:rgba(255,255,255,0.5);letter-spacing:2.5px;text-transform:uppercase;margin-bottom:1rem;font-weight:500;">
      Beyond Degrees · {course.weeks} Weeks · {course.delivery} · Certificate of Completion
    </p>

    <!-- Tagline -->
    <p style="font-size:18px;color:rgba(255,255,255,0.82);max-width:560px;margin:0 auto 2.5rem;line-height:1.6;">
      We don't teach you to fit into global health.<br />
      We teach you to <strong style="color:#fff;">lead, innovate, and transform it.</strong>
    </p>

    <!-- Meta badges -->
    <div style="display:flex;align-items:center;justify-content:center;gap:1rem;margin-bottom:2.5rem;flex-wrap:wrap;">
      {[
        { icon: "ti-calendar",    label: course.dates       },
        { icon: "ti-clock",       label: course.format      },
        { icon: "ti-world",       label: course.delivery    },
        { icon: "ti-certificate", label: "Certificate Included" },
      ].map(b => (
        <div style="border:1px solid rgba(201,146,42,0.35);padding:7px 14px;border-radius:2px;font-size:12px;color:rgba(255,255,255,0.72);display:flex;align-items:center;gap:7px;">
          <i class={`ti ${b.icon}`} style="font-size:14px;color:#C9922A;"></i>
          {b.label}
        </div>
      ))}
    </div>

    <!-- CTAs -->
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:3rem;">
      <a
        href="#register"
        style="background:#C9922A;color:#0B1C3D;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:15px 36px;border-radius:2px;text-decoration:none;display:inline-block;"
      >
        Apply for September 2026
      </a>
      <a
        href="#curriculum"
        style="background:transparent;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:600;letter-spacing:1px;text-transform:uppercase;padding:14px 28px;border:1px solid rgba(255,255,255,0.28);border-radius:2px;text-decoration:none;display:inline-block;"
      >
        Explore Curriculum
      </a>
    </div>

    <!-- Instructor trust line -->
    <div style="display:flex;align-items:center;justify-content:center;gap:12px;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.07);">
      <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#C9922A,#00A896);display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:800;color:#fff;flex-shrink:0;">LB</div>
      <div style="text-align:left;">
        <div style="font-size:13px;color:#fff;font-weight:500;">Led by {instructor.name}</div>
        <div style="font-size:11px;color:rgba(255,255,255,0.45);">{instructor.credentials} · University of Oxford · African Academy of Sciences</div>
      </div>
    </div>
  </div>
</section>
