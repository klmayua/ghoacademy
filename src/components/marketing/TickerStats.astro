---
import { SITE } from '../../data/site';

/**
 * Colour signals:
 *  gold   (#D6A43A) = urgency / deadlines / applications
 *  teal   (#1CC7C9) = programme features / learning
 *  amber  (#F59E0B) = achievements / credentials
 *  white  (default) = general info / network
 */
const tickerItems = [
  { icon: 'ti-calendar-event', text: 'Applications Open — September 2026', color: '#D6A43A', dot: '#D6A43A' },
  { icon: 'ti-award',          text: 'Scholarships Available',              color: '#F59E0B', dot: '#F59E0B' },
  { icon: 'ti-school',         text: 'Oxford-Affiliated Faculty',           color: '#1CC7C9', dot: '#1CC7C9' },
  { icon: 'ti-device-laptop',  text: 'Live Online · 8 Weeks',              color: '#1CC7C9', dot: '#1CC7C9' },
  { icon: 'ti-robot',          text: 'AI Module Included',                  color: '#1CC7C9', dot: '#1CC7C9' },
  { icon: 'ti-globe',          text: 'Global Impact Network',               color: 'rgba(255,255,255,0.7)', dot: 'rgba(255,255,255,0.35)' },
  { icon: 'ti-users',          text: '500+ Leaders Trained',                color: 'rgba(255,255,255,0.7)', dot: 'rgba(255,255,255,0.35)' },
  { icon: 'ti-clock',          text: 'Cohort 1 — Limited Seats',            color: '#D6A43A', dot: '#D6A43A' },
];
---

<!-- Trust + stats bar — sits directly below hero -->
<div id="trust-bar" style="background:#F5F0E8;border-bottom:1px solid rgba(214,164,58,0.3);position:relative;" class="light-section">

  <!-- Trust logos -->
  <div style="max-width:1440px;margin:0 auto;padding:1.75rem 2.5rem 0;">
    <p style="font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#B8862A;font-weight:700;text-align:center;margin-bottom:1.25rem;">Trusted by Global Leaders &amp; Institutions</p>
    <div style="display:flex;align-items:center;justify-content:center;gap:3rem;flex-wrap:wrap;padding-bottom:1.75rem;border-bottom:1px solid rgba(7,26,53,0.18);">
      {[
        { name: 'University of Oxford',       abbr: 'Oxford'  },
        { name: 'African Academy of Sciences', abbr: 'AAS'    },
        { name: 'EUCLID University',           abbr: 'EUCLID' },
        { name: 'Global Health Otherwise',     abbr: 'GHO'    },
        { name: 'University of Johannesburg',  abbr: 'UJ'     },
        { name: 'World Health Organization',   abbr: 'WHO'    },
      ].map(org => (
        <div style="text-align:center;transition:opacity 0.2s;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:800;color:#071A35;letter-spacing:2px;text-transform:uppercase;margin-bottom:3px;">{org.abbr}</div>
          <div style="font-size:10px;color:#071A35;white-space:nowrap;letter-spacing:0.5px;font-weight:500;">{org.name}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Metrics -->
  <div class="metrics-grid" style="max-width:1440px;margin:0 auto;padding:1.5rem 2.5rem 2rem;display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;">
    {[
      { num: '70+',  label: 'Countries Represented',     icon: 'ti-globe',         color: '#B8862A' },
      { num: '500+', label: 'Leaders Trained',            icon: 'ti-users',         color: '#0E7E80' },
      { num: '100+', label: 'Peer-reviewed Publications', icon: 'ti-file-text',     color: '#C47E0A' },
      { num: '1',    label: 'Global Impact Network',      icon: 'ti-topology-star', color: '#0E7E80' },
    ].map(s => (
      <div style={`background:#fff;border:1px solid rgba(7,26,53,0.12);border-top:3px solid ${s.color};border-radius:10px;padding:1.5rem 1rem;text-align:center;box-shadow:0 2px 8px rgba(7,26,53,0.06);`}>
        <i class={`ti ${s.icon}`} style={`font-size:22px;color:${s.color};display:block;margin-bottom:0.5rem;`}></i>
        <div style={`font-family:'Barlow Condensed',sans-serif;font-size:48px;font-weight:800;color:${s.color};line-height:1;margin-bottom:6px;`}>{s.num}</div>
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:#071A35;font-weight:700;">{s.label}</div>
      </div>
    ))}
  </div>
</div>

<style>
  @media (max-width: 768px) {
    .metrics-grid {
      grid-template-columns: 1fr 1fr !important;
      padding: 1.25rem !important;
      gap: 0.75rem !important;
    }
    #trust-bar > div:first-child {
      padding: 1.25rem 1.25rem 0 !important;
      gap: 1.5rem !important;
    }
  }
</style>
