---
---
<section id="about" style="position:relative;overflow:hidden;padding:8rem 2.5rem;background:#0E2237;">

  <!-- CINEMATIC FULL-BLEED IMAGE — merges into section, strong right presence -->
  <div style="position:absolute;inset:0;z-index:0;">
    <img
      src="/about-leaders.png"
      alt=""
      aria-hidden="true"
      style="width:100%;height:100%;object-fit:cover;object-position:center 30%;"
    />
    <!-- Gradient: strong left (content side), fades to let image breathe on right -->
    <div style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(14,34,55,0.98) 0%,rgba(14,34,55,0.9) 40%,rgba(14,34,55,0.55) 65%,rgba(14,34,55,0.15) 85%,transparent 100%);"></div>
    <!-- Top + bottom edge fades -->
    <div style="position:absolute;top:0;left:0;right:0;height:20%;background:linear-gradient(180deg,#0E2237 0%,transparent 100%);"></div>
    <div style="position:absolute;bottom:0;left:0;right:0;height:25%;background:linear-gradient(0deg,#0E2237 0%,transparent 100%);"></div>
  </div>

  <!-- CONTENT — floats over image, left-aligned -->
  <div style="max-width:1440px;margin:0 auto;position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">

    <!-- Left: headline + copy + tags -->
    <div>
      <p style="font-size:10px;letter-spacing:3.5px;text-transform:uppercase;color:#1CC7C9;font-weight:700;margin-bottom:1rem;display:flex;align-items:center;gap:8px;">
        <span style="width:20px;height:1px;background:#1CC7C9;display:inline-block;"></span>
        What Is GHO Academy
      </p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(36px,4vw,56px);font-weight:800;color:#F8F8F8;text-transform:uppercase;line-height:1;margin-bottom:1.25rem;">
        The Leadership Education<br /><span style="color:#D6A43A;">Global Health Was Missing</span>
      </h2>
      <p style="font-size:14px;color:rgba(248,248,248,0.68);line-height:1.8;margin-bottom:1rem;max-width:480px;">
        The global health system produces brilliant technical experts. It rarely produces bold, strategic leaders capable of navigating power, mobilizing funding, influencing policy, and driving systemic change.
      </p>
      <p style="font-size:14px;color:rgba(248,248,248,0.68);line-height:1.8;margin-bottom:1.75rem;max-width:480px;">
        GHO Academy fills that gap. In 8 weeks, you gain the tools, frameworks, network, and mindset that 17 years of global health leadership taught Dr. Bain — compressed into the most practical executive course in the field.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:8px;">
        {["Oxford-Affiliated Faculty","African-Led","AI-Integrated","Cohort-Based Live Learning","Stakeholder Capstone"].map(tag => (
          <span style="font-size:11px;background:rgba(14,34,55,0.7);backdrop-filter:blur(4px);color:#D6A43A;border:1px solid rgba(214,164,58,0.3);padding:5px 12px;border-radius:20px;font-weight:700;">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Right: stat cards -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
      {[
        { num: "30–50",  label: "Cohort size",        sub: "Intentionally small for impact"     },
        { num: "10",     label: "Live modules",        sub: "Each 2 hours with Dr. Bain"         },
        { num: "Global", label: "Participant network", sub: "Africa, UK, North America & beyond" },
        { num: "Real",   label: "Capstone outcomes",   sub: "Pitched to policymakers & funders"  },
      ].map(c => (
        <div style="background:rgba(14,34,55,0.72);backdrop-filter:blur(10px);border:1px solid rgba(214,164,58,0.18);padding:1.5rem;border-radius:12px;border-top:3px solid #D6A43A;transition:background 0.2s;" onmouseover="this.style.background='rgba(214,164,58,0.1)'" onmouseout="this.style.background='rgba(14,34,55,0.72)'">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:36px;font-weight:800;color:#D6A43A;line-height:1;margin-bottom:6px;">{c.num}</div>
          <div style="font-size:13px;font-weight:700;color:#fff;margin-bottom:3px;">{c.label}</div>
          <div style="font-size:11px;color:rgba(255,255,255,0.42);">{c.sub}</div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  @media (max-width: 900px) {
    #about > div:last-child { grid-template-columns: 1fr !important; gap: 2.5rem !important; }
    #about > div:first-child > div:first-of-type {
      background: linear-gradient(100deg, rgba(14,34,55,0.98) 0%, rgba(14,34,55,0.95) 100%) !important;
    }
    #about { padding: 6rem 1.5rem !important; }
  }
  @media (max-width: 480px) {
    #about > div:last-child > div:last-child { grid-template-columns: 1fr 1fr !important; }
  }
</style>
