---
import { MODULES } from '../../data/site';
---
<section id="curriculum" style="background:#EDE7D5;padding:4.5rem 2.5rem 9rem;position:relative;" class="light-section">
  <div style="max-width:1440px;margin:0 auto;">

    <div style="text-align:center;margin-bottom:4rem;">
      <p style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#0E6B6B;font-weight:700;margin-bottom:0.875rem;display:inline-flex;align-items:center;gap:8px;">
        <span style="width:20px;height:1px;background:#0E6B6B;display:inline-block;"></span>
        What You'll Learn
        <span style="width:20px;height:1px;background:#0E6B6B;display:inline-block;"></span>
      </p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(40px,5vw,64px);font-weight:800;color:#071A35;text-transform:uppercase;line-height:1;margin-bottom:1rem;">10 Core <span style="color:#B8862A;">Themes</span></h2>
      <p style="font-size:15px;color:rgba(7,26,53,0.55);max-width:520px;margin:0 auto;">
        Each module is a 2-hour live session combining expert instruction, peer discussion, case analysis, and real-world application.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      {MODULES.map((m, i) => (
        <a
          href={`/modules/${m.slug}`}
          style="background:#071A35;border:1px solid rgba(214,164,58,0.08);border-radius:14px;padding:1.5rem;display:flex;align-items:flex-start;gap:1.25rem;transition:background 0.2s,box-shadow 0.2s,border-color 0.2s;cursor:pointer;text-decoration:none;"
          onmouseover="this.style.background='#0D2745';this.style.boxShadow='0 6px 28px rgba(7,26,53,0.2)';this.style.borderColor='rgba(214,164,58,0.3)'"
          onmouseout="this.style.background='#071A35';this.style.boxShadow='none';this.style.borderColor='rgba(214,164,58,0.08)'"
        >
          <span style="font-family:'Barlow Condensed',sans-serif;font-size:36px;font-weight:800;color:rgba(214,164,58,0.5);line-height:1;min-width:40px;flex-shrink:0;">
            {m.num}
          </span>
          <div style="flex:1;">
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;color:#F5F0E8;text-transform:uppercase;letter-spacing:0.5px;line-height:1.2;margin-bottom:6px;display:flex;align-items:center;justify-content:space-between;gap:8px;">
              <span>
                {m.title}
                {m.tag && (
                  <span style="margin-left:8px;font-size:10px;background:rgba(28,199,201,0.12);color:#1CC7C9;padding:2px 8px;border-radius:20px;letter-spacing:1px;text-transform:uppercase;font-weight:700;vertical-align:middle;">
                    {m.tag}
                  </span>
                )}
              </span>
              <i class="ti ti-arrow-right" style="font-size:16px;color:rgba(214,164,58,0.5);flex-shrink:0;"></i>
            </div>
            <div style="font-size:13px;color:rgba(255,255,255,0.55);line-height:1.5;">{m.desc}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Section CTA -->
    <div style="text-align:center;margin-top:2rem;margin-bottom:0.5rem;">
      <a href="#register" style="display:inline-flex;align-items:center;gap:8px;background:#B8862A;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:13px 28px;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;" onmouseover="this.style.background='#9a7023';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#B8862A';this.style.transform=''">
        <i class="ti ti-arrow-right" style="font-size:16px;"></i>
        Apply Now — Enrol in All 10 Modules
      </a>
    </div>

    <!-- Capstone callout -->
    <div style="margin-top:2rem;background:#071A35;border:none;border-top:3px solid #D6A43A;padding:2.5rem;border-radius:14px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;">
        <div>
          <div style="font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#D6A43A;font-weight:700;margin-bottom:0.75rem;">Signature Experience</div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:800;color:#fff;text-transform:uppercase;margin-bottom:0.875rem;line-height:1;">Stakeholder-Driven Capstone Project</h3>
          <p style="font-size:14px;color:rgba(255,255,255,0.65);line-height:1.7;">Design and pitch a practical solution to a real global health challenge — presented to a professional audience of policymakers, funders, and implementers.</p>
          <a href="#register" style="display:inline-flex;align-items:center;gap:8px;margin-top:1.25rem;background:#D6A43A;color:#041326;font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:11px 22px;border-radius:6px;text-decoration:none;transition:background 0.2s;" onmouseover="this.style.background='#c49030'" onmouseout="this.style.background='#D6A43A'">
            <i class="ti ti-rocket" style="font-size:15px;"></i>
            Secure Your Place
          </a>
        </div>
        <div>
          {["Identify a pressing global health challenge","Develop an innovative, implementable solution","Receive structured faculty and peer feedback","Refine using systems thinking and implementation principles","Present to a professional stakeholder audience"].map(item => (
            <div style="display:flex;gap:12px;margin-bottom:12px;align-items:flex-start;">
              <div style="width:22px;height:22px;background:rgba(28,199,201,0.15);border:1px solid rgba(28,199,201,0.4);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">
                <i class="ti ti-check" style="font-size:11px;color:#1CC7C9;"></i>
              </div>
              <span style="font-size:14px;color:rgba(255,255,255,0.72);line-height:1.55;">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Wave divider: Curriculum (parchment) → Testimonials (dark #0D2040) -->
  <div style="position:absolute;bottom:-1px;left:0;width:100%;overflow:hidden;line-height:0;z-index:2;">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block;width:100%;height:80px;">
      <path d="M0,45 C300,8 600,52 900,22 C1100,4 1300,42 1440,45 L1440,60 L0,60 Z" fill="#0D2040"/>
    </svg>
  </div>
</section>

<style>
  @media (max-width: 900px) {
    #curriculum > div > div:nth-child(3) { grid-template-columns: 1fr !important; }
    #curriculum > div > div:last-child > div { grid-template-columns: 1fr !important; gap: 1.5rem !important; }
  }
  @media (max-width: 480px) {
    #curriculum { padding: 5rem 1.5rem !important; }
  }
</style>
