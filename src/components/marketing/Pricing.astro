---
import { SITE } from '../../data/site';
const { course } = SITE;
---
<section id="pricing" style="background:#060F22;padding:4.5rem 2.5rem;">
  <div style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:4rem;">
      <p style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#1CC7C9;font-weight:700;margin-bottom:0.875rem;display:inline-flex;align-items:center;gap:8px;">
        <span style="width:20px;height:1px;background:#1CC7C9;display:inline-block;"></span>
        Investment
        <span style="width:20px;height:1px;background:#1CC7C9;display:inline-block;"></span>
      </p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(40px,5vw,62px);font-weight:800;color:#F5F0E8;text-transform:uppercase;line-height:1;margin-bottom:1rem;">Course <span style="color:#D6A43A;">Pricing</span></h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.5);max-width:480px;margin:0 auto;">A fraction of the cost of comparable executive education at Oxford, Stellenbosch, or Saïd Business School — with the same calibre of instruction.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.5rem;align-items:start;margin-bottom:2rem;">

      <!-- Early Bird -->
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:14px;padding:2rem;position:relative;">
        <div style="position:absolute;top:-12px;left:1.5rem;background:#1CC7C9;color:#041326;font-size:10px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:4px 14px;border-radius:20px;">Limited Seats</div>
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,0.5);font-weight:600;margin-bottom:0.5rem;margin-top:0.5rem;">Early Bird</div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:56px;font-weight:800;color:#F5F0E8;line-height:1;margin-bottom:4px;">$397</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:1.5rem;">First 20 registrations only</div>
        {["Full 8-week course access","10 live sessions with Dr. Bain","Capstone project participation","Certificate of completion","Course materials & recordings","Alumni network access"].map(f => (
          <div style="display:flex;gap:8px;margin-bottom:8px;align-items:center;">
            <i class="ti ti-circle-check" style="font-size:15px;color:#1CC7C9;flex-shrink:0;"></i>
            <span style="font-size:13px;color:rgba(248,248,248,0.72);">{f}</span>
          </div>
        ))}
        <a href={course.stripeLink + "?priceId=early_bird"} style="display:block;margin-top:1.5rem;background:rgba(255,255,255,0.08);color:#F5F0E8;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:13px;text-align:center;border-radius:8px;text-decoration:none;border:1px solid rgba(255,255,255,0.15);transition:background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.14)'" onmouseout="this.style.background='rgba(255,255,255,0.08)'">Apply — Early Bird</a>
      </div>

      <!-- Standard (featured) -->
      <div style="background:rgba(214,164,58,0.08);border:2px solid #D6A43A;border-radius:14px;padding:2rem;position:relative;transform:scale(1.03);">
        <div style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#D6A43A;color:#041326;font-size:10px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:4px 16px;border-radius:20px;white-space:nowrap;">Most Popular</div>
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:2px;color:#D6A43A;font-weight:700;margin-bottom:0.5rem;margin-top:0.5rem;">Standard</div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:56px;font-weight:800;color:#F5F0E8;line-height:1;margin-bottom:4px;">$597</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.5);margin-bottom:1.5rem;">Standard registration price</div>
        {["Full 8-week course access","10 live sessions with Dr. Bain","Capstone project participation","Certificate of completion","Course materials & recordings","Alumni network access","Priority support from faculty"].map(f => (
          <div style="display:flex;gap:8px;margin-bottom:8px;align-items:center;">
            <i class="ti ti-circle-check" style="font-size:15px;color:#D6A43A;flex-shrink:0;"></i>
            <span style="font-size:13px;color:rgba(255,255,255,0.85);">{f}</span>
          </div>
        ))}
        <a href={course.stripeLink + "?priceId=standard"} style="display:block;margin-top:1.5rem;background:#D6A43A;color:#041326;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:13px;text-align:center;border-radius:8px;text-decoration:none;transition:background 0.2s;" onmouseover="this.style.background='#c49030'" onmouseout="this.style.background='#D6A43A'">Register Now</a>
      </div>

      <!-- Institutional -->
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:14px;padding:2rem;">
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,0.5);font-weight:600;margin-bottom:0.5rem;">Institutional</div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:56px;font-weight:800;color:#F5F0E8;line-height:1;margin-bottom:4px;">Custom</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:1.5rem;">3+ seats · Invoice available</div>
        {["Group discount (3+ participants)","Institutional invoice / PO accepted","Custom onboarding for your team","Progress reporting for managers","All standard course features","Dedicated faculty Q&A slot"].map(f => (
          <div style="display:flex;gap:8px;margin-bottom:8px;align-items:center;">
            <i class="ti ti-circle-check" style="font-size:15px;color:#1CC7C9;flex-shrink:0;"></i>
            <span style="font-size:13px;color:rgba(248,248,248,0.72);">{f}</span>
          </div>
        ))}
        <a href={`mailto:${SITE.email}?subject=GHO Academy Institutional Enquiry`} style="display:block;margin-top:1.5rem;background:transparent;color:#F5F0E8;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:12px;text-align:center;border-radius:8px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.5)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.2)'">Contact for Quote</a>
      </div>
    </div>

    <!-- Guarantee -->
    <div style="background:rgba(28,199,201,0.06);border:1px solid rgba(28,199,201,0.2);border-radius:14px;padding:1.5rem 2rem;display:flex;gap:1.5rem;align-items:center;">
      <i class="ti ti-shield-check" style="font-size:36px;color:#1CC7C9;flex-shrink:0;"></i>
      <div>
        <div style="font-weight:700;color:#F5F0E8;margin-bottom:4px;">Refund Policy</div>
        <p style="font-size:13px;color:rgba(255,255,255,0.55);line-height:1.6;">Full refund available up to 14 days before course start. 50% refund within 7 days of course start. We stand behind the quality of this programme — if it is not what we promised, we will make it right.</p>
      </div>
    </div>
  </div>
</section>

<!-- Registration CTA section -->
<section id="register" style="background:linear-gradient(135deg,#D6A43A 0%,#c49030 100%);padding:7rem 2.5rem;text-align:center;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 79px,rgba(4,19,38,0.04) 79px,rgba(4,19,38,0.04) 80px);pointer-events:none;"></div>
  <div style="max-width:800px;margin:0 auto;position:relative;">
    <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(50px,7vw,80px);font-weight:800;color:#041326;text-transform:uppercase;line-height:0.95;margin-bottom:0.875rem;">Secure Your Place.</h2>
    <p style="font-size:17px;color:rgba(4,19,38,0.7);margin-bottom:2.5rem;">{course.dates} · {course.weeks} Weeks · {course.delivery} · Certificate of Completion</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:1.75rem;">
      <a href={course.stripeLink + "?priceId=early_bird"} style="background:#041326;color:#D6A43A;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:16px 40px;border-radius:8px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:background 0.2s;" onmouseover="this.style.background='#071A35'" onmouseout="this.style.background='#041326'">Apply Now — Early Bird $397 <i class="ti ti-arrow-right" style="font-size:16px;"></i></a>
      <a href={`mailto:${SITE.email}?subject=GHO Academy Application — September 2026`} style="background:transparent;color:#041326;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:15px 28px;border:2px solid rgba(4,19,38,0.35);border-radius:8px;text-decoration:none;display:inline-block;transition:border-color 0.2s;" onmouseover="this.style.borderColor='rgba(4,19,38,0.7)'" onmouseout="this.style.borderColor='rgba(4,19,38,0.35)'">Request Info</a>
    </div>
    <p style="font-size:12px;text-transform:uppercase;letter-spacing:2px;color:rgba(4,19,38,0.5);font-weight:700;">Cohort 1 · Limited to {course.capacity} Participants · Closes When Full</p>
  </div>
</section>

<style>
  @media (max-width: 900px) {
    #pricing > div > div:nth-child(3) { grid-template-columns: 1fr !important; }
    #pricing > div > div:nth-child(3) > div:nth-child(2) { transform: none !important; }
  }
  @media (max-width: 480px) {
    #pricing { padding: 5rem 1.5rem !important; }
    #register { padding: 5rem 1.5rem !important; }
    #register > div > div:nth-child(3) { flex-direction: column !important; }
    #register > div > div:nth-child(3) > a { width: 100% !important; justify-content: center !important; }
  }
</style>
