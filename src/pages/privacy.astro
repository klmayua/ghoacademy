---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/shared/Nav.astro';
import Footer from '../components/shared/Footer.astro';
import { SITE } from '../data/site';
---
<BaseLayout title="Privacy Policy — GHO Academy">
  <Nav />
  <section style="background:#F5F3EE;padding:4rem 1.5rem;min-height:70vh;">
    <div style="max-width:760px;margin:0 auto;">
      <div style="margin-bottom:2.5rem;">
        <p style="font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#00A896;font-weight:600;margin-bottom:0.75rem;">Legal</p>
        <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(32px,5vw,48px);font-weight:800;color:#0B1C3D;text-transform:uppercase;margin-bottom:0.5rem;">Privacy Policy</h1>
        <p style="font-size:13px;color:#9CA3AF;">Last updated: June 2026 · GHO Academy / Global Health Otherwise</p>
      </div>
      <div style="background:#fff;border:1px solid #E8E5DE;border-radius:6px;padding:2.5rem;line-height:1.75;">
        {[
          { title:"1. Data We Collect",
            body:"We collect: name, email address, organisation, job title, country of residence, and optional professional bio at registration. We collect usage data (pages visited, sessions attended, assignments submitted) within the learning platform. We do not collect payment card data — this is processed securely by Stripe or Flutterwave."
          },
          { title:"2. How We Use Your Data",
            body:"Your data is used to: manage your enrolment and dashboard access; deliver session reminders and course communications; issue certificates; populate the cohort directory (name, role, country — you may opt out); and improve the course programme. We do not sell or share your data with third parties for marketing purposes."
          },
          { title:"3. Data Storage & Security",
            body:"Participant data is stored securely using industry-standard encryption. Access is restricted to GHO Academy programme staff. Session recordings are stored on secure cloud infrastructure and accessible only to enrolled cohort members."
          },
          { title:"4. Cookies",
            body:"We use essential cookies to maintain your login session. We do not use advertising or tracking cookies. You may disable cookies in your browser; this may affect dashboard functionality."
          },
          { title:"5. Data Retention",
            body:"Enrolment and certificate data is retained for 5 years for administrative purposes. Session recordings are retained for 12 months post-cohort. You may request deletion of your personal data by emailing us, subject to legal retention requirements."
          },
          { title:"6. Your Rights",
            body:"You have the right to: access the personal data we hold about you; correct inaccurate data; request deletion of your data; withdraw consent to non-essential communications at any time. To exercise these rights, contact us at the email below."
          },
          { title:"7. Contact",
            body:`Data controller: Global Health Otherwise / GHO Academy. Email: ${SITE.email}. For privacy-specific queries, include "Privacy Request" in your subject line.`
          },
        ].map(section => (
          <div style="margin-bottom:2rem;">
            <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;color:#0B1C3D;text-transform:uppercase;margin-bottom:0.75rem;">{section.title}</h2>
            <p style="font-size:14px;color:#4A5568;">{section.body}</p>
          </div>
        ))}
        <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid #E8E5DE;">
          <p style="font-size:13px;color:#9CA3AF;">Privacy questions? <a href={`mailto:${SITE.email}?subject=Privacy Request`} style="color:#C9922A;text-decoration:none;">{SITE.email}</a></p>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</BaseLayout>
