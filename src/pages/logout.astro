---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<script>setTimeout(() => { window.location.href = '/login'; }, 2000);</script>
<BaseLayout title="Signed Out — GHO Academy">
  <div style="min-height:100vh;background:#0B1C3D;display:flex;align-items:center;justify-content:center;padding:1.5rem;">
    <div style="text-align:center;max-width:380px;">
      <div style="font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;color:#fff;margin-bottom:4px;">GHO Academy</div>
      <div style="font-size:9px;color:#C9922A;letter-spacing:2.5px;font-weight:600;text-transform:uppercase;margin-bottom:2rem;">Global Health Otherwise</div>
      <div style="width:56px;height:56px;border-radius:50%;background:rgba(0,168,150,0.12);border:2px solid rgba(0,168,150,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
        <i class="ti ti-logout" style="font-size:24px;color:#00A896;"></i>
      </div>
      <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:800;color:#fff;text-transform:uppercase;margin-bottom:0.5rem;">You've Signed Out</h1>
      <p style="font-size:14px;color:rgba(255,255,255,0.45);margin-bottom:2rem;">See you next session.</p>
      <div style="display:flex;flex-direction:column;gap:0.75rem;">
        <a href="/login" style="background:#C9922A;color:#0B1C3D;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:13px;border-radius:2px;text-decoration:none;display:block;">Sign In Again</a>
        <a href="/" style="font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.4)'">Back to GHO Academy Home</a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // In production: clear session cookie/token here, then optionally redirect
  // sessionStorage.clear(); localStorage.clear();
</script>
