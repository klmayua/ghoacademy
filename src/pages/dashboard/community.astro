---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { COHORT_MEMBERS, DISCUSSION_THREADS } from '../../data/mock';

const members = COHORT_MEMBERS;
const _unusedMembers = [
  { initials:"AO", name:"Amara Okonkwo",     role:"Public Health Specialist", org:"WHO Nigeria",          country:"🇳🇬 Nigeria"   },
  { initials:"SK", name:"Samuel Kipkoech",   role:"Research Scientist",        org:"KEMRI, Kenya",         country:"🇰🇪 Kenya"     },
  { initials:"NM", name:"Nadia Mukasine",    role:"Health Policy Advisor",     org:"Rwanda MoH",           country:"🇷🇼 Rwanda"    },
  { initials:"PB", name:"Priya Bhattacharya",role:"Global Health Consultant",  org:"Independent",          country:"🇮🇳 India"     },
  { initials:"TA", name:"Temi Adeyemi",      role:"NGO Programme Manager",     org:"MSF West Africa",      country:"🇬🇭 Ghana"     },
  { initials:"CL", name:"Chidi Lebrun",      role:"Medical Officer",           org:"IPPF, Cameroon",       country:"🇨🇲 Cameroon"  },
  { initials:"GS", name:"Grace Ssemakula",   role:"Health Economist",          org:"Makerere University",  country:"🇺🇬 Uganda"    },
  { initials:"MA", name:"Mohamed Al-Hassan", role:"Policymaker",               org:"Sudan MoH",            country:"🇸🇩 Sudan"     },
];

const discussions = DISCUSSION_THREADS;
---
<DashboardLayout title="Community — GHO Academy" activeNav="community">

  <div style="margin-bottom:1.5rem;">
    <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:800;color:#0B1C3D;text-transform:uppercase;margin-bottom:4px;">Cohort Community</h1>
    <p style="font-size:14px;color:#4A5568;">Connect with your {members.length} fellow participants across Cohort 1.</p>
  </div>

  <div style="display:grid;grid-template-columns:1fr 300px;gap:1.5rem;">

    <!-- Left: discussions -->
    <div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;color:#0B1C3D;text-transform:uppercase;">Discussion Board</h2>
        <button id="new-post-btn" style="background:#0B1C3D;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;padding:8px 16px;border:none;border-radius:3px;cursor:pointer;display:flex;align-items:center;gap:5px;">
          <i class="ti ti-plus" style="font-size:14px;"></i>New Post
        </button>
      </div>

      <!-- New post panel (hidden by default) -->
      <div id="new-post-panel" style="display:none;background:#fff;border:1px solid #E8E5DE;border-radius:6px;padding:1.25rem;margin-bottom:1rem;">
        <input id="post-title" type="text" placeholder="Thread title..." style="width:100%;padding:9px 12px;border:1.5px solid #E8E5DE;border-radius:3px;font-size:14px;color:#1a1a2e;outline:none;margin-bottom:8px;" />
        <textarea id="post-body" rows="3" placeholder="Share your thoughts with the cohort..." style="width:100%;padding:9px 12px;border:1.5px solid #E8E5DE;border-radius:3px;font-size:14px;color:#1a1a2e;outline:none;resize:vertical;"></textarea>
        <div style="display:flex;gap:8px;margin-top:8px;">
          <button id="post-submit" style="background:#0B1C3D;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:700;padding:8px 16px;border:none;border-radius:3px;cursor:pointer;">Post</button>
          <button id="post-cancel" style="background:transparent;color:#4A5568;font-size:13px;padding:8px 14px;border:1.5px solid #E8E5DE;border-radius:3px;cursor:pointer;">Cancel</button>
        </div>
      </div>

      <div id="discussions-list" style="display:grid;gap:8px;margin-bottom:1.5rem;">
        {discussions.map(d => (
          <button onclick="window.showToast('Thread viewer coming in next release.')" style="background:#fff;border:1px solid #E8E5DE;border-radius:6px;padding:1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;transition:border-color 0.15s;cursor:pointer;width:100%;text-align:left;" onmouseover="this.style.borderColor='rgba(0,168,150,0.3)'" onmouseout="this.style.borderColor='#E8E5DE'">
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                {d.hot && <span style="font-size:10px;background:rgba(201,146,42,0.1);color:#C9922A;padding:2px 8px;border-radius:2px;font-weight:600;letter-spacing:0.5px;">Hot</span>}
                <h3 style="font-size:14px;font-weight:600;color:#0B1C3D;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{d.title}</h3>
              </div>
              <div style="display:flex;gap:1rem;">
                <span style="font-size:12px;color:#9CA3AF;display:flex;align-items:center;gap:4px;">
                  <i class="ti ti-message-circle" style="font-size:13px;"></i>{d.replies} replies
                </span>
                <span style="font-size:12px;color:#9CA3AF;display:flex;align-items:center;gap:4px;">
                  <i class="ti ti-eye" style="font-size:13px;"></i>{d.views} views
                </span>
              </div>
            </div>
            <i class="ti ti-chevron-right" style="font-size:16px;color:#E8E5DE;flex-shrink:0;"></i>
          </button>
        ))}
      </div>

      <!-- WhatsApp CTA -->
      <div style="background:#25D366;border-radius:6px;padding:1.25rem 1.5rem;display:flex;align-items:center;gap:1rem;">
        <i class="ti ti-brand-whatsapp" style="font-size:32px;color:#fff;flex-shrink:0;"></i>
        <div style="flex:1;">
          <div style="font-weight:600;color:#fff;margin-bottom:2px;">Cohort 1 WhatsApp Group</div>
          <div style="font-size:13px;color:rgba(255,255,255,0.8);">Join the group for real-time discussions, quick questions, and peer support between sessions.</div>
        </div>
        <a href="https://wa.me/" style="background:#fff;color:#25D366;font-weight:700;font-size:13px;padding:8px 16px;border-radius:3px;text-decoration:none;white-space:nowrap;">Join Group</a>
      </div>
    </div>

    <!-- Right: cohort members -->
    <div>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;color:#0B1C3D;text-transform:uppercase;margin-bottom:1rem;">Cohort Members</h2>
      <div style="display:grid;gap:8px;">
        {members.map(m => (
          <div style="background:#fff;border:1px solid #E8E5DE;border-radius:6px;padding:0.875rem 1rem;display:flex;align-items:center;gap:10px;">
            <div style="width:36px;height:36px;border-radius:50%;background:#0B1C3D;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#C9922A;flex-shrink:0;">{m.initials}</div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:13px;font-weight:600;color:#0B1C3D;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{m.name}</div>
              <div style="font-size:11px;color:#4A5568;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{m.role}</div>
              <div style="font-size:11px;color:#9CA3AF;">{m.country}</div>
            </div>
          </div>
        ))}
        <div style="text-align:center;padding:0.5rem;font-size:12px;color:#9CA3AF;">+{42 - members.length} more participants</div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  document.getElementById('new-post-btn')?.addEventListener('click', () => {
    const panel = document.getElementById('new-post-panel');
    if (panel) panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
  });
  document.getElementById('post-cancel')?.addEventListener('click', () => {
    const panel = document.getElementById('new-post-panel');
    if (panel) panel.style.display = 'none';
  });
  document.getElementById('post-submit')?.addEventListener('click', () => {
    const titleEl = document.getElementById('post-title') as HTMLInputElement;
    const bodyEl  = document.getElementById('post-body')  as HTMLTextAreaElement;
    const title = titleEl?.value.trim();
    if (!title) return;
    const list = document.getElementById('discussions-list');
    const card = document.createElement('button');
    card.onclick = () => (window as any).showToast('Thread viewer coming in next release.');
    card.style.cssText = 'background:#fff;border:1px solid rgba(0,168,150,0.3);border-radius:6px;padding:1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;cursor:pointer;width:100%;text-align:left;opacity:0;transition:opacity 0.3s;';
    card.innerHTML = `<div style="flex:1"><div style="font-size:14px;font-weight:600;color:#0B1C3D;">${title}</div><div style="font-size:12px;color:#9CA3AF;margin-top:4px;">0 replies · 1 view</div></div>`;
    list?.insertBefore(card, list.firstChild);
    requestAnimationFrame(() => { card.style.opacity = '1'; });
    titleEl.value = ''; bodyEl.value = '';
    const panel = document.getElementById('new-post-panel');
    if (panel) panel.style.display = 'none';
  });
</script>

<style>
  @media (max-width: 900px) {
    div[style*="grid-template-columns:1fr 300px"] { grid-template-columns: 1fr !important; }
  }
</style>
