---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { MODULES, SITE } from '../../data/site';
import { COHORT_STATS, RECENT_REGISTRATIONS } from '../../data/mock';

const stats = {
  enrolled: COHORT_STATS.enrolled, capacity: SITE.course.capacity,
  earlyBird: COHORT_STATS.early_bird_seats_taken, standard: COHORT_STATS.standard_seats_taken,
  revenue: COHORT_STATS.revenue_usd, target: COHORT_STATS.revenue_target_usd,
  completionRate: 100, avgAttendance: COHORT_STATS.module_1_attendance_rate,
};
const recentApps = RECENT_REGISTRATIONS.slice(0, 5).map(r => ({
  name: r.name, country: r.country, org: r.org, tier: r.tier,
  date: r.date, status: "confirmed"
}));
---
<AdminLayout title="Overview — GHO Academy Admin" activeNav="overview">

  <!-- KPI cards row -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem;">
    {[
      { label:"Enrolled",         val:`${stats.enrolled}`,            sub:`of ${stats.capacity} seats · ${Math.round(stats.enrolled/stats.capacity*100)}% full`,  color:"#0B1C3D", icon:"ti-users"          },
      { label:"Revenue (USD)",    val:`$${stats.revenue.toLocaleString()}`, sub:`Target $${stats.target.toLocaleString()} · ${Math.round(stats.revenue/stats.target*100)}% reached`, color:"#C9922A", icon:"ti-currency-dollar" },
      { label:"Module 1 Attended",val:`${stats.avgAttendance}%`,      sub:"Average attendance · 1 session",       color:"#00A896", icon:"ti-chart-bar"      },
      { label:"Days to Launch",   val:`${Math.round((new Date('2026-09-08').getTime()-Date.now())/86400000)}`,    sub:"Session 1 — Tue 8 Sep 2026",            color:"#4A5568", icon:"ti-clock"          },
    ].map(s => (
      <div style="background:#fff;border:1px solid #E8E5DE;border-radius:6px;padding:1.25rem;border-top:3px solid;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:0.75rem;">
          <span style="font-size:11px;text-transform:uppercase;letter-spacing:1px;color:#6B7280;font-weight:600;">{s.label}</span>
          <i class={`ti ${s.icon}`} style={`font-size:18px;color:${s.color};`}></i>
        </div>
        <div style={`font-family:'Barlow Condensed',sans-serif;font-size:38px;font-weight:800;color:${s.color};line-height:1;margin-bottom:4px;`}>{s.val}</div>
        <div style="font-size:11px;color:#9CA3AF;">{s.sub}</div>
      </div>
    ))}
  </div>

  <!-- Progress bars -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
    <div style="background:#fff;border:1px solid #E8E5DE;border-radius:6px;padding:1.25rem;">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
        <span style="font-size:13px;font-weight:600;color:#0B1C3D;">Enrolment Progress</span>
        <span style="font-size:13px;color:#4A5568;">{stats.enrolled}/{stats.capacity}</span>
      </div>
      <div style="height:10px;background:#E8E5DE;border-radius:9999px;overflow:hidden;margin-bottom:6px;">
        <div style={`height:100%;width:${stats.enrolled/stats.capacity*100}%;background:linear-gradient(90deg,#0B1C3D,#00A896);border-radius:9999px;`}></div>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:11px;color:#9CA3AF;">
        <span style="color:#00A896;font-weight:600;">{stats.earlyBird} early bird</span>
        <span>{stats.standard} standard</span>
        <span>{stats.capacity - stats.enrolled} seats remaining</span>
      </div>
    </div>
    <div style="background:#fff;border:1px solid #E8E5DE;border-radius:6px;padding:1.25rem;">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
        <span style="font-size:13px;font-weight:600;color:#0B1C3D;">Revenue vs Target</span>
        <span style="font-size:13px;color:#4A5568;">${stats.revenue.toLocaleString()} / ${stats.target.toLocaleString()}</span>
      </div>
      <div style="height:10px;background:#E8E5DE;border-radius:9999px;overflow:hidden;margin-bottom:6px;">
        <div style={`height:100%;width:${Math.min(stats.revenue/stats.target*100,100)}%;background:linear-gradient(90deg,#C9922A,#E5B84A);border-radius:9999px;`}></div>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:11px;color:#9CA3AF;">
        <span>Early Bird Rate $397</span>
        <span>Standard Rate $597</span>
      </div>
    </div>
  </div>

  <!-- Recent applications -->
  <div style="background:#fff;border:1px solid #E8E5DE;border-radius:6px;overflow:hidden;margin-bottom:1.5rem;">
    <div style="padding:1rem 1.25rem;border-bottom:1px solid #E8E5DE;display:flex;align-items:center;justify-content:space-between;">
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;color:#0B1C3D;text-transform:uppercase;">Recent Registrations</h2>
      <a href="/admin/participants" style="font-size:13px;color:#00A896;text-decoration:none;font-weight:500;">View all →</a>
    </div>
    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="background:#F5F3EE;">
            {["Participant","Country","Organisation","Tier","Date","Status"].map(h => (
              <th style="padding:9px 14px;text-align:left;font-size:11px;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid #E8E5DE;">{h}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {recentApps.map(a => (
            <tr style="border-bottom:1px solid #F5F3EE;" onmouseover="this.style.background='#FAFAF9'" onmouseout="this.style.background=''">
              <td style="padding:10px 14px;font-size:13px;font-weight:500;color:#0B1C3D;">{a.name}</td>
              <td style="padding:10px 14px;font-size:13px;color:#4A5568;">{a.country}</td>
              <td style="padding:10px 14px;font-size:13px;color:#4A5568;">{a.org}</td>
              <td style="padding:10px 14px;">
                <span style={`font-size:11px;font-weight:600;padding:2px 8px;border-radius:2px;${a.tier==='Early Bird'?'background:rgba(0,168,150,0.1);color:#00A896;':'background:rgba(201,146,42,0.1);color:#C9922A;'}`}>{a.tier}</span>
              </td>
              <td style="padding:10px 14px;font-size:12px;color:#9CA3AF;">{a.date}</td>
              <td style="padding:10px 14px;">
                <span style="font-size:11px;font-weight:600;background:rgba(0,168,150,0.08);color:#00A896;padding:2px 8px;border-radius:2px;">Confirmed</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Session status -->
  <div style="background:#fff;border:1px solid #E8E5DE;border-radius:6px;padding:1.25rem;">
    <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;color:#0B1C3D;text-transform:uppercase;margin-bottom:1rem;">Session Status</h2>
    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:6px;">
      {MODULES.map((m, i) => {
        const status = i === 0 ? 'done' : i === 1 ? 'next' : 'upcoming';
        return (
          <div style={`padding:0.75rem;border-radius:4px;border:1px solid ${status==='done'?'rgba(0,168,150,0.2)':status==='next'?'rgba(201,146,42,0.3)':'#E8E5DE'};background:${status==='done'?'rgba(0,168,150,0.04)':status==='next'?'rgba(201,146,42,0.04)':'#FAFAF9'};text-align:center;`}>
            <div style={`font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;color:${status==='done'?'#00A896':status==='next'?'#C9922A':'#D1D5DB'};line-height:1;margin-bottom:3px;`}>{m.num}</div>
            <div style="font-size:10px;color:#9CA3AF;font-weight:500;line-height:1.2;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">{m.title.split(' ').slice(0,3).join(' ')}</div>
          </div>
        );
      })}
    </div>
  </div>
</AdminLayout>

<style>
  @media (max-width: 1100px) {
    div[style*="grid-template-columns:repeat(4,1fr)"] { grid-template-columns: repeat(2,1fr) !important; }
    div[style*="grid-template-columns:repeat(5,1fr)"] { grid-template-columns: repeat(5,1fr) !important; }
  }
</style>
