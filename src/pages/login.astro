---
import BaseLayout from '../layouts/BaseLayout.astro';

const roles = [
  {
    id:       "student",
    label:    "Student",
    sub:      "Cohort 1 Participant",
    initials: "AO",
    name:     "Amara Okonkwo",
    org:      "WHO Nigeria",
    email:    "amara@who.int",
    password: "demo2026",
    redirect: "/dashboard",
    accent:   "#00A896",
    icon:     "ti-user-graduate",
  },
  {
    id:       "admin",
    label:    "Admin",
    sub:      "Course Coordinator",
    initials: "GA",
    name:     "GHO Admin",
    org:      "GHO Academy",
    email:    "admin@ghoacademy.org",
    password: "admin2026",
    redirect: "/admin",
    accent:   "#C9922A",
    icon:     "ti-settings",
  },
  {
    id:       "faculty",
    label:    "Faculty",
    sub:      "Programme Reviewer",
    initials: "SC",
    name:     "Prof. Sarah Chen",
    org:      "University of Oxford",
    email:    "faculty@oxfordgh.org",
    password: "faculty2026",
    redirect: "/dashboard",
    accent:   "#C9922A",
    icon:     "ti-school",
  },
  {
    id:       "partner",
    label:    "Partner",
    sub:      "University / Institution",
    initials: "TN",
    name:     "Dr. Thabo Nkosi",
    org:      "Stellenbosch University",
    email:    "partner@stellenbosch.ac.za",
    password: "partner2026",
    redirect: "/dashboard",
    accent:   "#00A896",
    icon:     "ti-building",
  },
  {
    id:       "assistant",
    label:    "T. Assistant",
    sub:      "Training Assistant",
    initials: "JO",
    name:     "James Owusu",
    org:      "GHO Academy",
    email:    "ta@ghoacademy.org",
    password: "ta2026",
    redirect: "/dashboard",
    accent:   "#00A896",
    icon:     "ti-clipboard-list",
  },
];
---
<BaseLayout title="Sign In — GHO Academy">
  <div style="min-height:100vh;background:#0B1C3D;display:flex;align-items:center;justify-content:center;padding:1.5rem;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 79px,rgba(201,146,42,0.03) 79px,rgba(201,146,42,0.03) 80px);pointer-events:none;"></div>

    <div style="width:100%;max-width:520px;position:relative;z-index:1;">

      <!-- Logo -->
      <div style="text-align:center;margin-bottom:2rem;">
        <a href="/" style="text-decoration:none;display:inline-block;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:800;color:#fff;letter-spacing:0.5px;">GHO Academy</div>
          <div style="font-size:10px;color:#C9922A;letter-spacing:2.5px;text-transform:uppercase;font-weight:600;margin-top:2px;">Global Health Otherwise</div>
        </a>
      </div>

      <!-- Role selector -->
      <div style="margin-bottom:1.5rem;">
        <div style="font-size:10px;font-weight:600;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:2px;text-align:center;margin-bottom:0.875rem;">Select your demo role to auto-fill</div>
        <div class="role-grid" style="display:flex;gap:8px;">
          {roles.map(r => (
            <button
              class="role-card"
              data-email={r.email}
              data-password={r.password}
              data-redirect={r.redirect}
              data-role={r.id}
              style={`flex:1;min-width:80px;background:rgba(255,255,255,0.03);border:1.5px solid rgba(255,255,255,0.08);border-radius:6px;padding:12px 8px;cursor:pointer;text-align:center;transition:all 0.2s;position:relative;overflow:hidden;`}
            >
              <div style={`width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.06);border:1.5px solid ${r.accent}33;display:flex;align-items:center;justify-content:center;margin:0 auto 6px;`}>
                <i class={`ti ${r.icon}`} style={`font-size:18px;color:${r.accent};`}></i>
              </div>
              <div style="font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:800;color:#fff;text-transform:uppercase;letter-spacing:0.3px;margin-bottom:2px;">{r.label}</div>
              <div style="font-size:10px;color:rgba(255,255,255,0.4);letter-spacing:0.2px;line-height:1.3;">{r.sub}</div>
              <div id={`role-check-${r.id}`} style="display:none;position:absolute;top:8px;right:8px;">
                <i class="ti ti-circle-check-filled" style={`font-size:14px;color:${r.accent};`}></i>
              </div>
            </button>
          ))}
        </div>

        <!-- Selected role preview -->
        <div id="selected-role-preview" style="margin-top:10px;background:rgba(0,168,150,0.06);border:1px solid rgba(0,168,150,0.18);border-radius:4px;padding:10px 14px;display:flex;align-items:center;gap:10px;opacity:0;pointer-events:none;transition:opacity 0.2s;">
          <div id="preview-avatar" style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#0B1C3D,#00A896);display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:800;color:#fff;flex-shrink:0;"></div>
          <div>
            <div id="preview-name" style="font-size:13px;font-weight:600;color:#fff;"></div>
            <div id="preview-org" style="font-size:11px;color:rgba(255,255,255,0.45);"></div>
          </div>
          <div style="margin-left:auto;">
            <i class="ti ti-arrow-right" style="font-size:16px;color:#00A896;"></i>
          </div>
        </div>
      </div>

      <!-- Login form card -->
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:6px;padding:2rem;">
        <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;color:#fff;text-transform:uppercase;margin-bottom:0.375rem;">Sign In</h1>
        <p style="font-size:13px;color:rgba(255,255,255,0.4);margin-bottom:1.5rem;">Click a role above or enter credentials manually.</p>

        <form id="login-form" action="#" style="display:grid;gap:1rem;">
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Email Address</label>
            <input id="email-input" type="email" name="email" required placeholder="you@organisation.org"
              style="width:100%;padding:11px 14px;background:rgba(255,255,255,0.06);border:1.5px solid rgba(255,255,255,0.1);border-radius:3px;font-size:14px;color:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#00A896'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
              <label style="font-size:11px;font-weight:600;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.5px;">Password</label>
              <a href="/forgot-password" style="font-size:12px;color:#C9922A;text-decoration:none;">Forgot password?</a>
            </div>
            <input id="password-input" type="password" name="password" required placeholder="••••••••"
              style="width:100%;padding:11px 14px;background:rgba(255,255,255,0.06);border:1.5px solid rgba(255,255,255,0.1);border-radius:3px;font-size:14px;color:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#00A896'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
          </div>

          <div style="display:flex;align-items:center;gap:8px;">
            <input type="checkbox" id="remember" style="accent-color:#00A896;" />
            <label for="remember" style="font-size:13px;color:rgba(255,255,255,0.5);cursor:pointer;">Remember me for 30 days</label>
          </div>

          <button id="signin-btn" type="submit"
            style="width:100%;background:#C9922A;color:#0B1C3D;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:13px;border:none;border-radius:2px;cursor:pointer;margin-top:0.25rem;transition:background 0.2s;"
            onmouseover="this.style.background='#B07820'" onmouseout="this.style.background='#C9922A'">
            Sign In
          </button>
          <div id="login-error" style="display:none;font-size:13px;color:#EF4444;margin-top:2px;text-align:center;line-height:1.4;">Invalid credentials. Select a demo role above.</div>
        </form>

        <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,0.07);text-align:center;">
          <p style="font-size:13px;color:rgba(255,255,255,0.4);">
            Not enrolled yet?
            <a href="/apply" style="color:#C9922A;font-weight:600;text-decoration:none;margin-left:4px;">Apply for Cohort 1 →</a>
          </p>
        </div>
      </div>

      <div style="text-align:center;margin-top:1.25rem;">
        <a href="/" style="font-size:13px;color:rgba(255,255,255,0.3);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='rgba(255,255,255,0.65)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
          ← Back to GHO Academy
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const ROLES = [
    { id:"student",   label:"Student",     email:"amara@who.int",               password:"demo2026",     redirect:"/dashboard", initials:"AO", name:"Amara Okonkwo",    country:"Nigeria",        org:"WHO Nigeria",            progress:30,  accent:"#00A896" },
    { id:"admin",     label:"Admin",       email:"admin@ghoacademy.org",        password:"admin2026",    redirect:"/admin",     initials:"GA", name:"GHO Admin",       country:"Global",         org:"GHO Academy",            progress:0,   accent:"#C9922A" },
    { id:"faculty",   label:"Faculty",     email:"faculty@oxfordgh.org",        password:"faculty2026",  redirect:"/dashboard", initials:"SC", name:"Prof. Sarah Chen", country:"United Kingdom", org:"University of Oxford",   progress:80,  accent:"#C9922A" },
    { id:"partner",   label:"Partner",     email:"partner@stellenbosch.ac.za",  password:"partner2026",  redirect:"/dashboard", initials:"TN", name:"Dr. Thabo Nkosi",  country:"South Africa",  org:"Stellenbosch University",progress:0,   accent:"#00A896" },
    { id:"assistant", label:"T. Assistant",email:"ta@ghoacademy.org",           password:"ta2026",       redirect:"/dashboard", initials:"JO", name:"James Owusu",      country:"Ghana",          org:"GHO Academy",            progress:100, accent:"#00A896" },
  ];

  let activeRole: string | null = null;

  document.querySelectorAll('.role-card').forEach(card => {
    card.addEventListener('click', () => {
      const btn   = card as HTMLElement;
      const rid   = btn.dataset.role!;
      const role  = ROLES.find(r => r.id === rid)!;
      activeRole  = rid;

      // Fill inputs
      (document.getElementById('email-input')    as HTMLInputElement).value = role.email;
      (document.getElementById('password-input') as HTMLInputElement).value = role.password;

      // Update card selection state
      document.querySelectorAll('.role-card').forEach(c => {
        const el = c as HTMLElement;
        el.style.borderColor  = 'rgba(255,255,255,0.08)';
        el.style.background   = 'rgba(255,255,255,0.03)';
        el.style.boxShadow    = 'none';
        const chk = document.getElementById(`role-check-${el.dataset.role}`);
        if (chk) chk.style.display = 'none';
      });
      const accent = (role as any).accent || '#00A896';
      btn.style.borderColor = accent;
      btn.style.background  = `${accent}14`;
      btn.style.boxShadow   = `0 0 0 1px ${accent}40`;
      const chk = document.getElementById(`role-check-${rid}`);
      if (chk) chk.style.display = 'block';

      // Update Sign In button text
      const signinBtn = document.getElementById('signin-btn');
      if (signinBtn) signinBtn.textContent = `Sign In as ${role.label} →`;

      // Show preview
      const preview = document.getElementById('selected-role-preview');
      const avatar  = document.getElementById('preview-avatar');
      const nameEl  = document.getElementById('preview-name');
      const orgEl   = document.getElementById('preview-org');
      if (preview) { preview.style.opacity = '1'; preview.style.pointerEvents = 'auto'; }
      if (avatar)  { avatar.textContent = role.initials; avatar.style.background = `linear-gradient(135deg,#0B1C3D,${(role as any).accent || '#00A896'})`; }
      if (nameEl)  nameEl.textContent = role.name;
      if (orgEl)   orgEl.textContent  = role.org;

      // Clear error
      const errEl = document.getElementById('login-error');
      if (errEl) errEl.style.display = 'none';
    });
  });

  document.getElementById('login-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email    = (document.getElementById('email-input')    as HTMLInputElement).value.trim();
    const password = (document.getElementById('password-input') as HTMLInputElement).value;
    const errEl    = document.getElementById('login-error');
    const btn      = document.getElementById('signin-btn') as HTMLButtonElement;

    // Match against all 5 demo roles
    const matched = ROLES.find(r => r.email === email && r.password === password);

    if (matched) {
      if (errEl) errEl.style.display = 'none';
      // Save role context to sessionStorage
      sessionStorage.setItem('gho_role',     matched.id);
      sessionStorage.setItem('gho_name',     matched.name);
      sessionStorage.setItem('gho_initials', matched.initials);
      sessionStorage.setItem('gho_country',  matched.country);
      sessionStorage.setItem('gho_org',      matched.org);
      sessionStorage.setItem('gho_progress', String(matched.progress));
      btn.textContent  = 'Signing in...';
      btn.style.opacity = '0.75';
      btn.disabled = true;
      setTimeout(() => { window.location.href = matched.redirect; }, 700);
    } else {
      if (errEl) errEl.style.display = 'block';
    }
  });
</script>

<style>
  .role-card:hover {
    border-color: rgba(255,255,255,0.2) !important;
    background: rgba(255,255,255,0.06) !important;
  }
  @media (max-width: 520px) {
    .role-grid { flex-wrap: wrap !important; }
    .role-grid .role-card { width: calc(50% - 4px) !important; flex: none !important; }
    .role-grid .role-card:last-child:nth-child(odd) { width: 100% !important; }
  }
</style>
