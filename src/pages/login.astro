---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Sign In — GHO Academy">
  <div style="min-height:100vh;background:#0B1C3D;display:flex;align-items:center;justify-content:center;padding:1.5rem;position:relative;overflow:hidden;">
    <!-- Background texture -->
    <div style="position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 79px,rgba(201,146,42,0.03) 79px,rgba(201,146,42,0.03) 80px);pointer-events:none;"></div>

    <div style="width:100%;max-width:420px;position:relative;z-index:1;">

      <!-- Logo -->
      <div style="text-align:center;margin-bottom:2.5rem;">
        <a href="/" style="text-decoration:none;display:inline-block;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:800;color:#fff;letter-spacing:0.5px;">GHO Academy</div>
          <div style="font-size:10px;color:#C9922A;letter-spacing:2.5px;text-transform:uppercase;font-weight:600;margin-top:2px;">Global Health Otherwise</div>
        </a>
      </div>

      <!-- Card -->
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:6px;padding:2.5rem;">
        <div style="background:rgba(0,168,150,0.08);border:1px solid rgba(0,168,150,0.2);border-radius:4px;padding:10px 14px;font-size:12px;color:rgba(255,255,255,0.65);margin-bottom:1.25rem;line-height:1.5;">Demo credentials: <strong style="color:#00A896;">amara@who.int</strong> / <strong style="color:#00A896;">demo2026</strong></div>
        <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:800;color:#fff;text-transform:uppercase;margin-bottom:0.5rem;">Welcome Back</h1>
        <p style="font-size:13px;color:rgba(255,255,255,0.45);margin-bottom:2rem;">Sign in to access your student dashboard.</p>

        <form id="login-form" action="#" style="display:grid;gap:1rem;">
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Email Address</label>
            <input type="email" name="email" required placeholder="you@organisation.org"
              style="width:100%;padding:11px 14px;background:rgba(255,255,255,0.06);border:1.5px solid rgba(255,255,255,0.1);border-radius:3px;font-size:14px;color:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#00A896'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
              <label style="font-size:11px;font-weight:600;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.5px;">Password</label>
              <a href="/forgot-password" style="font-size:12px;color:#C9922A;text-decoration:none;">Forgot password?</a>
            </div>
            <input type="password" name="password" required placeholder="••••••••"
              style="width:100%;padding:11px 14px;background:rgba(255,255,255,0.06);border:1.5px solid rgba(255,255,255,0.1);border-radius:3px;font-size:14px;color:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#00A896'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
          </div>

          <div style="display:flex;align-items:center;gap:8px;">
            <input type="checkbox" id="remember" style="accent-color:#00A896;" />
            <label for="remember" style="font-size:13px;color:rgba(255,255,255,0.5);cursor:pointer;">Remember me for 30 days</label>
          </div>

          <button type="submit"
            style="width:100%;background:#C9922A;color:#0B1C3D;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:13px;border:none;border-radius:2px;cursor:pointer;margin-top:0.5rem;transition:background 0.2s;"
            onmouseover="this.style.background='#B07820'" onmouseout="this.style.background='#C9922A'">
            Sign In
          </button>
          <div id="login-error" style="display:none;font-size:13px;color:#EF4444;margin-top:6px;line-height:1.4;">Invalid credentials. Use the demo credentials shown above.</div>
        </form>

        <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,0.07);text-align:center;">
          <p style="font-size:13px;color:rgba(255,255,255,0.4);">
            Not enrolled yet?
            <a href="/apply" style="color:#C9922A;font-weight:600;text-decoration:none;margin-left:4px;">Apply for Cohort 1 →</a>
          </p>
        </div>
      </div>

      <!-- Back link -->
      <div style="text-align:center;margin-top:1.5rem;">
        <a href="/" style="font-size:13px;color:rgba(255,255,255,0.35);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.35)'">
          ← Back to GHO Academy
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.getElementById('login-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const email = (form.querySelector('input[type="email"]') as HTMLInputElement)?.value.trim();
    const password = (form.querySelector('input[type="password"]') as HTMLInputElement)?.value;
    const errEl = document.getElementById('login-error');
    if (email === 'amara@who.int' && password === 'demo2026') {
      if (errEl) errEl.style.display = 'none';
      setTimeout(() => { window.location.href = '/dashboard'; }, 600);
    } else {
      if (errEl) errEl.style.display = 'block';
    }
  });
</script>
